# MongoDB URI
MONGO_URI=mongodb://127.0.0.1:27017/gems-crm

# Redis (rate limiting distribuido y ban de IPs)
# Render: crear un Redis add-on y copiar la Internal URL
# Upstash (gratuito): https://upstash.com → Redis → Connect → ioredis URL
# Sin configurar: usa memoria (solo válido en dev local, no persiste entre reinicios)
REDIS_URL=redis://localhost:6379

# JWT Secret Key
JWT_SECRET=gems-crm-secret-key-2024-super-secure

# Server Port
PORT=4000

# Environment
NODE_ENV=development

# GitHub Integration (optional)
GITHUB_TOKEN=your_github_personal_access_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
APP_URL=http://localhost:4000

# Google Gemini API (proxy desde /api/ai/gemini-generate)
# Obtener en https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
